# =============================================================================
# LOCAL DEVELOPMENT CONFIGURATION OVERRIDES
# =============================================================================
# This file contains only local-specific configuration.
# It overrides values from base.env when sourced by deployment scripts.

# =============================================================================
# DEPLOYMENT ENVIRONMENT
# =============================================================================
DEPLOYMENT_ENV=local

# =============================================================================
# LOCAL SERVICE URLS
# =============================================================================
# Override for local development
LEGEND_ENGINE_URL=http://localhost:6300
LEGEND_SDLC_URL=http://localhost:6100
LEGEND_STUDIO_URL=http://localhost:9000

# For Docker Compose internal networking
LEGEND_ENGINE_INTERNAL_URL=http://legend-engine:6300
LEGEND_SDLC_INTERNAL_URL=http://legend-sdlc:6100
LEGEND_STUDIO_INTERNAL_URL=http://legend-studio:9000

# =============================================================================
# MONGODB CONFIGURATION (Local)
# =============================================================================
# Override for local MongoDB container
MONGODB_URI=mongodb://admin:admin@mongodb:27017/legend?authSource=admin
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=admin
MONGO_DATABASE=legend

# =============================================================================
# GUARDIAN AGENT CONFIGURATION (Local)
# =============================================================================
LEGEND_API_KEY=demo-key
VALID_API_KEYS=demo-key,test-key
LEGEND_API_DEBUG=true

# =============================================================================
# LOCAL RESOURCE LIMITS
# =============================================================================
# Lower limits for local development
ENGINE_MEMORY_REQUEST=256Mi
ENGINE_MEMORY_LIMIT=1Gi
ENGINE_CPU_REQUEST=100m
ENGINE_CPU_LIMIT=500m

# =============================================================================
# DOCKER COMPOSE PROFILES
# =============================================================================
# Profiles for selective service startup
COMPOSE_PROFILES=full  # Options: core, full, guardian

# =============================================================================
# LOCAL DEVELOPMENT SETTINGS
# =============================================================================
NODE_ENV=development
LOG_LEVEL=DEBUG
ENABLE_MONITORING=false
ENABLE_TLS=false