# =============================================================================
# SECRETS TEMPLATE
# =============================================================================
# Copy this file to secrets.env in the project root and fill in your real values
# This file is safe to commit as it contains no real secrets
#
# The configuration hierarchy is:
# 1. base.env - Shared base configuration
# 2. azure/azure.env or local/local.env - Environment-specific overrides
# 3. secrets.env - Your actual secrets (this file when copied)
#
# Only put actual secrets in this file, not configuration

# =============================================================================
# AZURE INFRASTRUCTURE SECRETS (Required for Azure deployment)
# =============================================================================
# Get these from your Azure Portal
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=rs-finos-legend
AZURE_ACR_USERNAME=your-acr-username
AZURE_ACR_PASSWORD=your-acr-password

# =============================================================================
# GITLAB OAUTH SECRETS (Required for SDLC)
# =============================================================================
# Get these from GitLab: https://gitlab.com/-/profile/applications
GITLAB_APP_ID=your-gitlab-app-id
GITLAB_APP_SECRET=your-gitlab-app-secret

# =============================================================================
# PRODUCTION URLS (Required for Azure deployment)
# =============================================================================
# Replace with your actual domain names
LEGEND_ENGINE_URL=https://legend-engine.your-domain.com
LEGEND_SDLC_URL=https://legend-sdlc.your-domain.com
LEGEND_STUDIO_URL=https://legend-studio.your-domain.com
TLS_CERT_DOMAIN=legend.your-domain.com
TLS_CERT_EMAIL=your-email@domain.com

# =============================================================================
# MONGODB PRODUCTION CONNECTION (Required for Azure with Cosmos DB)
# =============================================================================
# Replace [PASSWORD] and [UNIQUE_SUFFIX] with actual values from Azure
MONGODB_URI=mongodb://admin:[PASSWORD]@mongo-legend-[UNIQUE_SUFFIX].mongo.cosmos.azure.com:10255/legend?ssl=true&replicaSet=globaldb&retrywrites=false&maxIdleTimeMS=120000&appName=@mongo-legend-[UNIQUE_SUFFIX]@

# =============================================================================
# API KEYS (Optional - for Guardian Agent)
# =============================================================================
# Generate secure keys for production
VALID_API_KEYS=generate-secure-key-1,generate-secure-key-2
